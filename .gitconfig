[core]
	excludesfile = /Users/timoptimothy/.gitignore_global
	editor = nvim
[diff]
  tool = nvimdiff
[merge]
  tool = nvimdiff3
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[difftool "nvimdiff"]
	cmd = nvim -d \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "nvimdiff"]
	cmd = nvim -d \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[user]
	name = Timothy
	email = timothytimothytimo6@gmail.com
	signingkey = 3748061515B564A2A32EEB27AB870CF30786EFA9
[commit]
	template = /Users/timoptimothy/.stCommitMsg
	gpgsign = true
[tag]
	gpgSign = true
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = false
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[alias]
	pull-allow = pull --allow-unrelated-histories
	co = commit --allow-empty
  a = add
[advice]
	defaultBranchName = false
[credential]
	helper = osxkeychain
[includeIf "gitdir:~/Developer/github_repository/ttiimmothhy/"]
  path = ~/.gitconfig-not-often
