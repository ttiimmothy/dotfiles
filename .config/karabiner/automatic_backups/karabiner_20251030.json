                    {
                        "description": "Open activity monitor by option+\\",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "caps_lock pressed",
                                            "value": 1
                                        }
                                    }
                                ],
                                "to_after_key_up": [
                                    {
                                        "set_variable": {
                                            "name": "caps_lock pressed",
                                            "value": 0
                                        }
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "name": "caps_lock pressed",
                                        "type": "variable_if",
                                        "value": 0
                                    }
                                ],
                                "from": {
                                    "key_code": "backslash",
                                    "modifiers": { "mandatory": ["option"] }
                                },
                                "to": { "shell_command": "open '/System/Applications/Utilities/Activity Monitor.app'" },
                                "type": "basic"
                            }
                        ]
                    },
